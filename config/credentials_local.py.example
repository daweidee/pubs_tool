# 本地私密配置（示例文件）
# 复制为 credentials_local.py，并填入你自己的值。该文件已加入 .gitignore，不会提交到仓库。

# === AWS 访问密钥 ===
AWS_ACCESS_KEY_ID = "你的AK"
AWS_SECRET_ACCESS_KEY = "你的SK"

# 如果你用的是临时凭证（STS），再填写 Session Token；否则留空/None
AWS_SESSION_TOKEN = None

# === S3 ===
# 桶名称（与 settings.py 中默认值一致时可省略，仅环境变量/本地二选一即可）
S3_BUCKET = "bucket-test"

# 区域，如 ap-northeast-1
AWS_REGION = "ap-northeast-1"
